{
  "name": "@juliodiazru/open-context-map",
  "version": "0.1.2",
  "description": "Local code context map with CLI and MCP support for opencode.",
  "homepage": "https://github.com/juliodiazru/open-context-map#readme",
  "bugs": {
    "url": "https://github.com/juliodiazru/open-context-map/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliodiazru/open-context-map.git"
  },
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "open-context-map": "./src/cli.js"
  },
  "files": [
    "src/",
    "README.md",
    "SECURITY.md",
    "docs/"
  ],
  "scripts": {
    "test": "node --test",
    "validate:interest-lab": "node scripts/validate-interest-lab.mjs",
    "audit": "pnpm audit --audit-level moderate",
    "check": "pnpm test && pnpm audit --audit-level moderate"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "opencode",
    "code-graph",
    "context-engine",
    "repo-map"
  ],
  "license": "MIT",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.27.1"
  }
}
