{
  "name": "open-context-map",
  "version": "0.1.0",
  "description": "Mapa local de contexto de codigo con CLI y MCP para opencode.",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "open-context-map": "./src/cli.js"
  },
  "files": [
    "src/",
    "README.md",
    "SECURITY.md",
    "docs/"
  ],
  "scripts": {
    "test": "node --test",
    "validate:interest-lab": "node scripts/validate-interest-lab.mjs",
    "audit": "pnpm audit --audit-level moderate",
    "check": "pnpm test && pnpm audit --audit-level moderate"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "opencode",
    "code-graph",
    "context-engine",
    "repo-map"
  ],
  "license": "MIT"
}
