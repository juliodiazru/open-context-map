{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "open-context-map": {
      "type": "local",
      "command": [
        "node",
        "src/cli.js",
        "mcp",
        "."
      ],
      "enabled": true,
      "timeout": 15000
    }
  },
  "watcher": {
    "ignore": [
      ".open-context-map/**",
      "node_modules/**",
      ".gradle/**",
      "build/**",
      "target/**",
      "dist/**"
    ]
  }
}
